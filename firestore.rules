rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('Admin');
    }

    function isDocs() {
      return hasRole('Docs') || hasRole('Admin');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Validation Helpers
    function isValidJob(data) {
      return data.keys().hasAll(['id', 'jobCode', 'customerId']) &&
             data.id is string && data.id.size() <= 128 &&
             data.jobCode is string && data.jobCode.size() <= 64 &&
             data.customerId is string && data.customerId.size() <= 128 &&
             (data.get('cost', 0) is number) &&
             (data.get('sell', 0) is number);
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['id', 'code', 'name']) &&
             data.id is string && data.id.size() <= 128 &&
             data.code is string && data.code.size() <= 64 &&
             data.name is string && data.name.size() <= 256;
    }

    // 2. Collection Rules
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && 
                       incoming().role == 'Cus'; // Force default role for self-reg if any
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId && incoming().role == existing().role);
    }

    match /jobs/{jobId} {
      allow read: if isDocs();
      allow create: if isDocs() && isValidJob(incoming());
      allow update: if isDocs() && isValidJob(incoming()) && (
        isAdmin() || (incoming().diff(existing()).affectedKeys().hasOnly(['cvhcUrl', 'cvhcFileName', 'updatedAt']))
      );
      allow delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isDocs();
      allow create: if isDocs() && isValidCustomer(incoming());
      allow update: if isDocs() && isValidCustomer(incoming());
      allow delete: if isAdmin();
    }

    match /lines/{lineId} {
      allow read: if isDocs();
      allow write: if isDocs();
    }

    match /paymentRequests/{requestId} {
      allow read: if isDocs();
      allow create: if isDocs();
      allow update: if isDocs();
      allow delete: if isAdmin();
    }
    
    match /salaries/{salaryId} {
      allow read, write: if isAdmin();
    }

    match /yearlyConfigs/{configId} {
      allow read: if isDocs();
      allow write: if isAdmin();
    }

    match /nfcProfiles/{profileId} {
      allow read: if true; // Public profiles
      allow write: if isDocs();
    }
    
    match /longHoangOrders/{orderId} {
      allow read: if isDocs();
      allow write: if isDocs();
    }
  }
}
