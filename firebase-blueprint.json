{
  "entities": {
    "Authorization": {
      "title": "Authorization",
      "description": "Văn bản ủy quyền (Power of Attorney) giữa các khách hàng",
      "type": "object",
      "properties": {
        "principalId": {
          "type": "string",
          "description": "Bên ủy quyền (Customer ID)"
        },
        "agentId": {
          "type": "string",
          "description": "Bên được ủy quyền (Customer ID)"
        },
        "expiryDate": {
          "type": "string",
          "description": "Thời hạn hiệu lực (YYYY-MM-DD)"
        },
        "attachmentUrl": {
          "type": "string",
          "description": "URL file đính kèm"
        },
        "attachmentName": {
          "type": "string",
          "description": "Tên file đính kèm"
        },
        "year": {
          "type": "integer",
          "description": "Năm hiệu lực để lọc"
        },
        "createdAt": {
          "type": "string",
          "description": "Thời gian tạo"
        }
      },
      "required": ["principalId", "agentId", "expiryDate", "year"]
    }
  },
  "firestore": {
    "authorizations/{authorizationId}": {
      "schema": "Authorization",
      "description": "Danh sách các ủy quyền"
    }
  }
}
